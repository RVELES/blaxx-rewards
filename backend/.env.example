# Blaxx Pontos Backend — variaveis de ambiente
# Copie para .env e ajuste conforme necessario.

# Flask
FLASK_ENV=development
SECRET_KEY=troque-este-valor-em-producao-use-secrets-token-hex-32
APP_URL=http://localhost:8000

# Database
DATABASE_URL=sqlite:///instance/blaxx.db

# CORS — separar origens por virgula
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Email
# Opcoes: console (apenas log) | smtp
EMAIL_BACKEND=console
EMAIL_FROM=noreply@blaxx.com.br
EMAIL_FROM_NAME=Blaxx Pontos

# SMTP (somente se EMAIL_BACKEND=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Google OAuth (Fase 2 — pode deixar em branco na Fase 1)
GOOGLE_CLIENT_ID=

# SMS (Twilio) — em dev, deixe SMS_BACKEND=console e o codigo sai no log
SMS_BACKEND=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# Timers (segundos)
PHONE_OTP_TTL=600
MFA_CHALLENGE_TTL=300
PHONE_OTP_COOLDOWN=60

# Tokens (segundos)
EMAIL_VERIFICATION_TOKEN_TTL=86400
PASSWORD_RESET_TOKEN_TTL=3600
SESSION_TTL=2592000

# Rate limit (tentativas por janela)
LOGIN_RATE_LIMIT_PER_IP=20
LOGIN_RATE_LIMIT_WINDOW=600
RESEND_VERIFICATION_COOLDOWN=60
