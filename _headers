# Configuracao de cache + seguranca pro Netlify CDN.
# https://docs.netlify.com/routing/headers/

# Sprint 3 (S3-5): headers de seguranca globais em todas as paginas.
# CSP allowlist do que o site realmente usa: Google Fonts pra Inter,
# Google Identity Services pro login, API origin do backend.
# Aceita 'unsafe-inline' em style porque varias paginas tem style="..."
# inline herdado — futuro: nonce-based CSP.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://accounts.google.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://accounts.google.com https://blaxx-pontos-backend.onrender.com https://blaxx-pontos-backend.fly.dev; frame-src https://accounts.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# HTML: nunca cachear no browser (sempre verifica server)
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# JS / CSS: cache curto + revalidacao. Mudancas aparecem em ~1 min sem hard refresh.
/assets/*
  Cache-Control: public, max-age=60, must-revalidate

# Fontes e imagens: cache longo (nao mudam frequentemente)
/assets/icons/*
  Cache-Control: public, max-age=2592000, immutable
